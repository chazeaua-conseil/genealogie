// Genealogy app — Prisma schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth.js v5 — Prisma adapter tables
// https://authjs.dev/getting-started/adapters/prisma
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  accounts        Account[]
  sessions        Session[]
  treeMembers     TreeMember[]
  invitationsSent TreeInvitation[] @relation("TreeInvitedBy")

  // Audit trail across entities
  personsCreated   Person[]   @relation("PersonCreatedBy")
  personsUpdated   Person[]   @relation("PersonUpdatedBy")
  eventsCreated    Event[]    @relation("EventCreatedBy")
  familiesCreated  Family[]   @relation("FamilyCreatedBy")
  placesCreated    Place[]    @relation("PlaceCreatedBy")
  sourcesCreated   Source[]   @relation("SourceCreatedBy")
  mediaCreated     Media[]    @relation("MediaCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Domain — Trees & access
// ---------------------------------------------------------------------------

enum TreeRole {
  OWNER
  EDITOR
  VIEWER
}

model Tree {
  id          String   @id @default(cuid())
  name        String
  description String?

  members      TreeMember[]
  invitations  TreeInvitation[]
  persons      Person[]
  families     Family[]
  events       Event[]
  places       Place[]
  sources      Source[]
  citations    Citation[]
  media        Media[]
  relationships Relationship[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TreeMember {
  id     String   @id @default(cuid())
  treeId String
  userId String
  role   TreeRole @default(EDITOR)

  tree Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([treeId, userId])
  @@index([userId])
}

// Pending invitation by email. When a user signs in with a matching email,
// the Auth.js signIn callback consumes the invitation and creates a
// TreeMember automatically.
model TreeInvitation {
  id          String    @id @default(cuid())
  treeId      String
  email       String
  role        TreeRole  @default(EDITOR)
  invitedById String?
  acceptedAt  DateTime?

  tree         Tree  @relation(fields: [treeId], references: [id], onDelete: Cascade)
  invitedBy    User? @relation("TreeInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([treeId, email])
  @@index([email])
}

// ---------------------------------------------------------------------------
// Domain — Persons & families
// ---------------------------------------------------------------------------

enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

model Person {
  id     String @id @default(cuid())
  treeId String

  // Name components — kept granular for search and rendering
  givenName  String? // prénoms
  surname    String? // nom de famille à la naissance
  marriedName String? // nom d'usage / nom marital
  nickname   String?
  prefix     String? // M., Mme, Dr., Père…
  suffix     String? // Jr., Sr., II…

  sex      Sex     @default(UNKNOWN)
  isLiving Boolean @default(false) // par défaut: ancêtre décédé
  privacy  Boolean @default(false) // true = masquer infos sensibles aux non-éditeurs

  notes String? @db.Text

  tree Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  // Events where this person is the primary subject
  events        Event[]             @relation("EventPerson")
  participations EventParticipant[]

  // Family roles
  familiesAsSpouseA Family[] @relation("FamilySpouseA")
  familiesAsSpouseB Family[] @relation("FamilySpouseB")
  childInFamilies   FamilyChild[]

  // Direct parent-child relations (alternative to FamilyChild, for filiations hors union)
  parentRelations Relationship[] @relation("RelationshipParent")
  childRelations  Relationship[] @relation("RelationshipChild")

  citations Citation[]
  media     Media[]

  createdById String?
  createdBy   User?   @relation("PersonCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("PersonUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treeId, surname])
  @@index([treeId, givenName])
}

enum FamilyType {
  MARRIAGE
  UNION
  RELIGIOUS
  OTHER
}

model Family {
  id     String     @id @default(cuid())
  treeId String
  type   FamilyType @default(MARRIAGE)

  spouseAId String?
  spouseBId String?
  spouseA   Person? @relation("FamilySpouseA", fields: [spouseAId], references: [id])
  spouseB   Person? @relation("FamilySpouseB", fields: [spouseBId], references: [id])

  notes String? @db.Text

  tree     Tree          @relation(fields: [treeId], references: [id], onDelete: Cascade)
  children FamilyChild[]
  events   Event[]       @relation("EventFamily")

  citations Citation[]

  createdById String?
  createdBy   User?   @relation("FamilyCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treeId, spouseAId])
  @@index([treeId, spouseBId])
}

enum FilialLink {
  BIOLOGICAL
  ADOPTIVE
  FOSTER
  STEP
  RECOGNIZED
  UNKNOWN
}

model FamilyChild {
  id       String     @id @default(cuid())
  familyId String
  childId  String
  link     FilialLink @default(BIOLOGICAL)
  notes    String?

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  child  Person @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([familyId, childId])
  @@index([childId])
}

// Direct parent-child link, alternative to FamilyChild, for cases where
// the parent's union is unknown or not modeled as a Family.
model Relationship {
  id       String     @id @default(cuid())
  treeId   String
  parentId String
  childId  String
  link     FilialLink @default(BIOLOGICAL)
  notes    String?

  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  parent Person @relation("RelationshipParent", fields: [parentId], references: [id], onDelete: Cascade)
  child  Person @relation("RelationshipChild", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([treeId, childId])
}

// ---------------------------------------------------------------------------
// Domain — Events (typed, dated, with uncertainty)
// ---------------------------------------------------------------------------

enum EventType {
  BIRTH
  DEATH
  MARRIAGE
  DIVORCE
  BAPTISM
  CONFIRMATION
  BURIAL
  CREMATION
  CENSUS
  IMMIGRATION
  EMIGRATION
  NATURALIZATION
  OCCUPATION
  RESIDENCE
  EDUCATION
  MILITARY_SERVICE
  WILL
  PROBATE
  OTHER
}

enum DateQualifier {
  EXACT
  ABOUT     // vers
  BEFORE    // avant
  AFTER     // après
  BETWEEN   // entre date1 et date2
  ESTIMATED // estimé
}

enum ParticipantRole {
  WITNESS
  OFFICIANT
  GODPARENT
  INFORMANT
  OTHER
}

model Event {
  id     String    @id @default(cuid())
  treeId String
  type   EventType

  // Date with uncertainty support
  date          DateTime?     // exact or start of range
  dateEnd       DateTime?     // end of range for BETWEEN
  dateQualifier DateQualifier @default(EXACT)
  dateText      String?       // textual representation if structured date unknown ("été 1850")

  placeId String?

  // Either personId OR familyId is set (primary subject)
  personId String?
  familyId String?

  description String? @db.Text
  notes       String? @db.Text

  tree   Tree    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  place  Place?  @relation(fields: [placeId], references: [id])
  person Person? @relation("EventPerson", fields: [personId], references: [id], onDelete: Cascade)
  family Family? @relation("EventFamily", fields: [familyId], references: [id], onDelete: Cascade)

  participants EventParticipant[]
  citations    Citation[]
  media        Media[]

  createdById String?
  createdBy   User?   @relation("EventCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treeId, type])
  @@index([personId])
  @@index([familyId])
  @@index([treeId, date])
}

model EventParticipant {
  id       String          @id @default(cuid())
  eventId  String
  personId String
  role     ParticipantRole

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([eventId, personId, role])
  @@index([personId])
}

// ---------------------------------------------------------------------------
// Domain — Places
// ---------------------------------------------------------------------------

model Place {
  id     String  @id @default(cuid())
  treeId String
  name   String  // commune principalement
  // Hierarchy (we keep it flat — name + dept + region + country sufficient for MVP)
  department String? // département
  region     String? // région
  country    String? @default("France")
  latitude   Float?
  longitude  Float?
  notes      String?

  tree   Tree    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  events Event[]

  createdById String?
  createdBy   User?   @relation("PlaceCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treeId, name])
}

// ---------------------------------------------------------------------------
// Domain — Sources & citations
// ---------------------------------------------------------------------------

enum SourceType {
  BIRTH_CERTIFICATE
  DEATH_CERTIFICATE
  MARRIAGE_CERTIFICATE
  PARISH_REGISTER
  CENSUS
  NEWSPAPER
  PERSONAL_RECORD
  ARCHIVE
  WEBSITE
  ORAL_TESTIMONY
  OTHER
}

enum CitationQuality {
  LOW
  MEDIUM
  HIGH
}

model Source {
  id     String     @id @default(cuid())
  treeId String
  type   SourceType @default(OTHER)
  title  String
  author String?
  publisher String?
  date    DateTime?
  reference String? // cote d'archive, ISBN, URL, etc.
  notes  String? @db.Text

  tree      Tree       @relation(fields: [treeId], references: [id], onDelete: Cascade)
  citations Citation[]
  media     Media[]

  createdById String?
  createdBy   User?   @relation("SourceCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treeId, title])
}

// A citation links a source to a specific fact (event, person, family).
// Exactly one of eventId/personId/familyId should be set in practice.
model Citation {
  id       String          @id @default(cuid())
  treeId   String
  sourceId String
  page     String?
  date     DateTime? // when the source was accessed/consulted
  quality  CitationQuality @default(MEDIUM)
  notes    String?         @db.Text

  eventId  String?
  personId String?
  familyId String?

  tree   Tree    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  source Source  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  event  Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person Person? @relation(fields: [personId], references: [id], onDelete: Cascade)
  family Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([sourceId])
  @@index([eventId])
  @@index([personId])
  @@index([familyId])
}

// ---------------------------------------------------------------------------
// Domain — Media (photos, scans of acts, etc.)
// ---------------------------------------------------------------------------

model Media {
  id     String  @id @default(cuid())
  treeId String

  filename String
  url      String  // chemin relatif sur disque ou URL
  mimeType String?
  size     Int?
  caption  String?
  date     DateTime?

  // Attachable to one of: person, event, source
  personId String?
  eventId  String?
  sourceId String?

  tree   Tree    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  person Person? @relation(fields: [personId], references: [id], onDelete: Cascade)
  event  Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  source Source? @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("MediaCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([personId])
  @@index([eventId])
  @@index([sourceId])
}
